# Rename this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.

# 1. Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Create a free cluster at https://cloud.qdrant.io
#    Copy the Cluster URL (e.g. https://xyz.us-east4-0.gcp.cloud.qdrant.io)
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io

# 3. Copy the API key shown in the Qdrant Cloud dashboard
QDRANT_API_KEY=your_qdrant_api_key_here
